# top-most EditorConfig file
root = true

# Defaults for every file
[*]
indent_style = space
end_of_line = lf
charset = utf-8

insert_final_newline = true
trim_trailing_whitespace = true

max_line_length = 152

# Idris source files
[*.{idr,ipkg,tex,yaff,lidr}]
indent_size = 2

# Various configuration files
[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[*.{c,h}]
indent_size = 4

[*.{md,rst}]
indent_size = 2

[{*.sh,run,.rename,.convert-run-to-print-tests,tar-pack,*.bat,.patch-*}]
indent_size = 2
shell_variant = posix
switch_case_indent = true
space_redirects = true

[{Makefile,*.mk}]
indent_style = tab

[expected]
indent_style = unset
trim_trailing_whitespace = false
max_line_length = off

[.clean-names]
max_line_length = off

[*.py]
indent_size = 4

# See: https://stackoverflow.com/a/40348831/2572373
[**{.build,docs/build}**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
max_line_length = unset
